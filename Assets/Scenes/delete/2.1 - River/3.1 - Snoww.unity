      m_Calls: []
  m_text: "\u041C\u0456\u0441\u044F\u0446\u044C - \u043C\u043E\u0436\u043D\u0430
    \u0432\u0438\u043A\u043E\u0440\u0438\u0441\u0430\u0442\u0438\u0442\u0438 \u0448\u0435\u0439\u0434\u0440
    \u044F\u043A\u0438\u0439 \u0454 \u0432 \u0441\u0442\u0430\u0440\u043E\u043C\u0443
    \u043F\u0440\u043E\u0435\u043A\u0442\u0456\n\n\u043B\u0456\u0441, \u0432\u043E\u0434\u0430,
    \n\n\u043C\u043E\u0436\u0435 \u0437\u043E\u0440\u0456 = \u043A\u0430\u043F\u043B\u0456
    = \u0441\u043D\u0456\u0436\u0438\u043D\u043A\u0438. \u0430 \u043C\u0456\u0441\u044F\u0446\u044C
    \u043C\u043E\u0436\u0435 \u0431\u0443\u0442\u0438 \u044F\u043A \u0456 \u043D\u0430
    \u043D\u0435\u0431\u0456 \u0442\u0430\u043A \u0456 \u0432\u0456\u0434\u0431\u0438\u0442\u0442\u044F\u043C
    \u0443 \u0432\u043E\u0434\u0456\n\n"
